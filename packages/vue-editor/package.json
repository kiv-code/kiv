{
	"name": "@kivcode/vue-editor",
	"version": "0.1.4",
	"description": "The Kiv visual page-builder editor UI — canvas, structure tree, inspector, drag & drop, undo/redo, node palette, and content-block library.",
	"license": "MIT",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kiv-code/kiv.git",
		"directory": "packages/vue-editor"
	},
	"homepage": "https://github.com/kiv-code/kiv/tree/main/packages/vue-editor#readme",
	"bugs": "https://github.com/kiv-code/kiv/issues",
	"keywords": [
		"kiv",
		"page-builder",
		"visual-editor",
		"vue",
		"vue3"
	],
	"author": "Kivcode",
	"publishConfig": {
		"access": "public"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs"
		},
		"./style": "./dist/vue-editor.css"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "vite build",
		"test": "vitest run",
		"typecheck": "vue-tsc --noEmit"
	},
	"dependencies": {
		"@kivcode/engine": "workspace:*",
		"@kivcode/nodes": "workspace:*",
		"@kivcode/nodes-interactive": "workspace:*",
		"@kivcode/vue": "workspace:*"
	},
	"devDependencies": {
		"@vitejs/plugin-vue": "^5.2.4",
		"@vue/test-utils": "^2.4.11",
		"happy-dom": "^20.10.6",
		"typescript": "^6.0.3",
		"vite": "^6.3.5",
		"vite-plugin-dts": "^4.5.4",
		"vitest": "^4.1.9",
		"vue-tsc": "^2.2.12"
	},
	"peerDependencies": {
		"vue": "^3.5.0"
	}
}
