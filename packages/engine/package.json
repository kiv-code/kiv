{
	"name": "@kivcode/engine",
	"version": "0.1.0",
	"description": "Headless, JSON-driven document engine for the Kiv visual page-builder — document model, registry, field schema, history, and plugin system. No UI framework dependency.",
	"license": "MIT",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kiv-code/kiv.git",
		"directory": "packages/engine"
	},
	"homepage": "https://github.com/kiv-code/kiv/tree/main/packages/engine#readme",
	"bugs": "https://github.com/kiv-code/kiv/issues",
	"keywords": [
		"kiv",
		"page-builder",
		"visual-editor",
		"headless-cms",
		"json-schema"
	],
	"author": "Kivcode",
	"publishConfig": {
		"access": "public"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "unbuild",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@vue/reactivity": "^3.5.38",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"typescript": "^6.0.3",
		"unbuild": "^3.6.1",
		"vitest": "^4.1.9"
	}
}
