{
	"name": "@kivcode/nodes-interactive",
	"version": "0.1.0",
	"description": "Stateful interactive nodes (Accordion, Tabs, Modal, Carousel) and the content-block template library for the Kiv visual page-builder.",
	"license": "MIT",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kiv-code/kiv.git",
		"directory": "packages/nodes-interactive"
	},
	"homepage": "https://github.com/kiv-code/kiv/tree/main/packages/nodes-interactive#readme",
	"bugs": "https://github.com/kiv-code/kiv/issues",
	"keywords": [
		"kiv",
		"page-builder",
		"visual-editor"
	],
	"author": "Kivcode",
	"publishConfig": {
		"access": "public"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
