{
	"name": "@kivcode/nodes",
	"version": "0.1.0",
	"description": "Pure node schema and defaults for the Kiv visual page-builder — layout, content, and media node definitions with no rendering components.",
	"license": "MIT",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kiv-code/kiv.git",
		"directory": "packages/nodes"
	},
	"homepage": "https://github.com/kiv-code/kiv/tree/main/packages/nodes#readme",
	"bugs": "https://github.com/kiv-code/kiv/issues",
	"keywords": [
		"kiv",
		"page-builder",
		"visual-editor"
	],
	"author": "Kivcode",
	"publishConfig": {
