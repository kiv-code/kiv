		"@iconify/types": "^2.0.0",
		"@iconify/utils": "^3.1.4",
		"@kivcode/engine": "workspace:*",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"typescript": "^6.0.3",
		"unbuild": "^3.6.1",
		"vitest": "^4.1.9"
