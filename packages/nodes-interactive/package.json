	"dependencies": {
		"@kivcode/engine": "workspace:*",
		"@kivcode/nodes": "workspace:*"
	},
	"devDependencies": {
		"typescript": "^6.0.3",
		"unbuild": "^3.6.1",
		"vitest": "^4.1.9"
	}
